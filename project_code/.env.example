# MCP credentials — copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit secrets.

# --- Figma (Designer Agent) ---
# Get a personal access token: https://www.figma.com/developers/api#access-tokens
# Read-only scope is sufficient.
FIGMA_API_KEY=
FIGMA_FILE_URL=

# --- GitHub (DevOps Agent) ---
# Create a fine-scoped PAT: https://github.com/settings/personal-access-tokens
# Scopes needed: repo (read/write), workflow.
GITHUB_TOKEN=
GITHUB_REPO_URL=
GITHUB_DEFAULT_BRANCH=main

# --- Vercel (DevOps Agent — skip if not deploying to Vercel) ---
# Create an access token: https://vercel.com/account/tokens
# Also update the team-slug/project-slug in .mcp.json.
VERCEL_TOKEN=
VERCEL_TEAM_SLUG=
VERCEL_PROJECT_SLUG=

# --- Supabase (Architect + DEV agents — only if project uses Supabase) ---
# Leave blank for projects that don't use Supabase.

# MCP management token — build-time only, used by agents to inspect/migrate schema.
# Get one at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Project identifiers — found in Supabase dashboard
SUPABASE_PROJECT_REF=
SUPABASE_URL=

# Runtime keys — used by the deployed app (backend + frontend) to connect to Supabase.
# Find them at https://supabase.com/dashboard/project/<REF>/settings/api
SUPABASE_ANON_KEY=

# Optional — only set if your backend needs server-side privileged operations.
# NEVER expose this to the frontend / mobile client. Treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=

# --- Mobile (Flutter Agent + DevOps — skip if web-only) ---
BUNDLE_ID=
APPLE_TEAM_ID=
IOS_DISTRIBUTION_CHANNEL=TestFlight
ANDROID_PACKAGE=
ANDROID_DISTRIBUTION_CHANNEL=
